# Supabase (already in use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://arwignplanners.com

# Stripe (already in use)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- NEW: Pillar 1 additions ---

# Resend (email provider)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Per-category "from" addresses — must be on a domain verified in Resend
EMAIL_FROM_INFO=Arwign Planners <info@arwignplanners.com>
EMAIL_FROM_SALES=Arwign Planners <sales@arwignplanners.com>
EMAIL_FROM_SUPPORT=Arwign Planners <support@arwignplanners.com>
EMAIL_WEBHOOK_SECRET=

# Nurture cron protection
# Generate: openssl rand -hex 32
CRON_SECRET=

# Receives admin notifications (e.g. new personalized notebook requests)
ADMIN_EMAIL=admin@arwignplanners.com

# PayPal (checkout buttons + server capture)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_ENV=sandbox

# PesaPal (Visa / Mastercard checkout)
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# sandbox (cybqa.pesapal.com) | live (pay.pesapal.com)
PESAPAL_ENV=live
# Optional — pin a previously-registered IPN id to skip re-registering on every cold start
PESAPAL_IPN_ID=

# Google Analytics 4 measurement id
NEXT_PUBLIC_GA_MEASUREMENT_ID=
